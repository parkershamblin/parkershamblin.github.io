{
  "name": "@once-ui-system/magic-portfolio",
  "version": "2.2.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:static": "next build",
    "build:worker": "cross-env NEXT_DEPLOY_TARGET=worker opennextjs-cloudflare build",
    "preview:worker": "cross-env NEXT_DEPLOY_TARGET=worker opennextjs-cloudflare preview",
    "deploy:worker": "npm run build:worker && npm run upload:worker",
    "upload:worker": "wrangler deploy",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run build:static",
    "deploy": "npm run build:static"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "^16.2.6",
    "@once-ui-system/core": "^1.7.3",
    "classnames": "^2.5.1",
    "compressorjs": "^1.3.0",
    "cookie": "^1.1.1",
    "gray-matter": "^4.0.3",
    "next": "^16.2.6",
    "next-mdx-remote": "^6.0.0",
    "prismjs": "^1.30.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-icons": "^5.6.0",
    "react-masonry-css": "^1.0.16",
    "recharts": "^3.8.1",
    "sass": "^1.99.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.10",
    "@types/cookie": "^1.0.0",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.92.0"
  },
  "overrides": {
    "postcss": "8.5.14"
  }
}
